{
  "hooks": {
    "UserPromptSubmit": [],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|StrReplace|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -ExecutionPolicy Bypass -File .claude/hooks/hook-pre-tool-use.ps1"
          },
          {
            "type": "command",
            "command": "pwsh -ExecutionPolicy Bypass -File .claude/hooks/hook-violation-scanner.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -ExecutionPolicy Bypass -File .claude/hooks/hook-stop.ps1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "disableBypassPermissionsMode": "disable"
  }
}

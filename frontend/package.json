  "description": "Next.js 14 + TypeScript frontend for the JARVIS AI Life Management System.",
  "main": "index.js",
  "scripts": {
    "clean-port": "node scripts/clean-port.cjs",
    "predev": "npm run clean-port",
    "dev": "next dev -p 3000 --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check-deps": "ts-node ../scripts/setup/check_dependencies.ts",

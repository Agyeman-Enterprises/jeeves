    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.86.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "class-variance-authority": "^0.7.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.7",
    "lucide-react": "^0.575.0",
    "next": "^16.0.7",
    "openai": "^6.22.0",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
